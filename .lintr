linters: linters_with_defaults(
    line_length_linter(120L),
    object_name_linter(styles = c("snake_case", "CamelCase", "dotted.case")),
    object_length_linter(length = 40L),
    # S7 classes (e.g. PmedResult) and internal dot-functions (.pmed_*) are
    # resolved at runtime, so lintr's static pass reports spurious
    # "no visible global function" notes. Disable to avoid the noise.
    object_usage_linter = NULL
  )
exclusions: list(
    "inst/doc"
  )
encoding: "UTF-8"
